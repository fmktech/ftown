{
  "name": "ftown-bridge",
  "version": "0.2.3",
  "description": "CLI bridge for ftown — generic PTY-over-Centrifugo relay",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ftown-bridge": "dist/index.js"
  },
  "files": [
    "dist",
    "hooks"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "pty",
    "centrifugo",
    "orchestrator",
    "terminal",
    "bridge"
  ],
  "author": "fmktech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmktech/ftown.git",
    "directory": "bridge"
  },
  "dependencies": {
    "centrifuge": "^5.2.2",
    "commander": "^13.1.0",
    "node-pty": "^1.2.0-beta.12",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
